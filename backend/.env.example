# ============================================================================
# AstroCRM v3.0.0 - Complete Environment Configuration Template
# ============================================================================
#
# INSTRUCTIONS:
# 1. Copy this file to .env (in same folder as this .env.example)
# 2. Fill in the actual values for your setup
# 3. DO NOT commit .env to git - only commit this .env.example file
# 4. Restart backend after making changes: npm run dev
#
# ============================================================================


# ──────────────────────────────────────────────────────────────────────────
# SERVER CONFIGURATION
# ──────────────────────────────────────────────────────────────────────────

# Port where the API server will run
PORT=3001

# JSON Web Token secret for user authentication
# Change this to a random, secure string in production!
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-12345


# ──────────────────────────────────────────────────────────────────────────
# DATABASE CONFIGURATION (PostgreSQL 17)
# ──────────────────────────────────────────────────────────────────────────

# PostgreSQL database username
PG_USER=postgres

# PostgreSQL database password
# Default during install: postgres
# Change this if you set a different password during PostgreSQL installation
PG_PASSWORD=postgres

# PostgreSQL server hostname
# Default: localhost (same machine)
# For remote database: use IP or domain name
PG_HOST=localhost

# PostgreSQL server port
PG_PORT=5432

# PostgreSQL database name
# Auto-created if it doesn't exist
PG_DATABASE=astrocrm


# ──────────────────────────────────────────────────────────────────────────
# AI/ML CONFIGURATION (Optional)
# ──────────────────────────────────────────────────────────────────────────

# ASI:One AI API Key (Optional)
# Leave blank to disable AI features (system works fine without it)
# Get free key at: https://www.asiresearch.org
# Features that need this:
# - AI Chat in Insights tab
# - AI-powered dashboard summaries
# - Campaign message generation
# - Sales forecasting
ASI_ONE_API_KEY=

# Alternative: Groq API Key (free alternative, not used by default)
# GROQ_API_KEY=gsk_your_groq_api_key_here


# ──────────────────────────────────────────────────────────────────────────
# FEATURES / FEATURE FLAGS (Optional)
# ──────────────────────────────────────────────────────────────────────────

# Enable/disable Google Sheets integration
GOOGLE_SHEETS_ENABLED=true

# Enable/disable Online Store (e-commerce)
ONLINE_STORE_ENABLED=true

# Enable/disable SMS campaigns
SMS_ENABLED=false

# Enable/disable Email campaigns
EMAIL_ENABLED=false


# ============================================================================
# EXAMPLE SETUPS
# ============================================================================

# EXAMPLE 1: Local development (Windows/Mac/Linux)
# PG_USER=postgres
# PG_PASSWORD=postgres
# PG_HOST=localhost
# PG_PORT=5432
# PG_DATABASE=astrocrm
# Port=3001
# JWT_SECRET=dev-secret-key-12345

# EXAMPLE 2: Production with remote database
# PG_USER=prod_user
# PG_PASSWORD=super-secure-password-here
# PG_HOST=db.example.com
# PG_PORT=5432
# PG_DATABASE=astrocrm_prod
# PORT=3001
# JWT_SECRET=very-long-random-production-secret-key-here-change-this

# EXAMPLE 3: With AI features enabled
# ASI_ONE_API_KEY=sk_live_abc123def456ghi789jkl

# ============================================================================
# TROUBLESHOOTING
# ============================================================================

# Q: Backend won't start with "PG_PASSWORD not found" error
# A: Make sure .env file exists in the backend/ folder (not root folder)
#    And make sure the file is named exactly ".env" (with the dot)

# Q: "Cannot connect to database" error
# A: Verify PostgreSQL is running and check these settings:
#    - PG_HOST: correct server address
#    - PG_PORT: correct port (usually 5432)
#    - PG_USER: correct username (usually "postgres")
#    - PG_PASSWORD: correct password
#    - PG_DATABASE: database exists (create if missing with SQL command)

# Q: "Connection refused" on port 3001
# A: Either port 3001 is already in use, or backend didn't start
#    Change PORT=3001 to PORT=3002 and restart

# Q: Where should this file go?
# A: In the backend folder: backend/.env
#    NOT in root folder, NOT in frontend folder

# Q: Do I need to fill everything?
# A: Minimum required for launch:
#    - PORT
#    - JWT_SECRET
#    - PG_USER, PG_PASSWORD, PG_HOST, PG_PORT, PG_DATABASE
#    Optional: ASI_ONE_API_KEY (AI features)

# ============================================================================
# QUICK START
# ============================================================================

# 1. Save this as "backend/.env"
# 2. Fill in PG_PASSWORD to match your PostgreSQL password
# 3. Run: npm run dev
# 4. Backend should start on http://localhost:3001
# 5. You'll see: "📡 Server running on http://localhost:3001"

# ============================================================================
